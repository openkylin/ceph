Description: Switch back to static linking
  Resolves linking failures on ppc64el
Author: James Page <james.page@canonical.com>
Forwarded: not-needed

--- a/src/common/CMakeLists.txt
+++ b/src/common/CMakeLists.txt
@@ -230,7 +230,7 @@
     crc32c_aarch64.c)
 endif(HAVE_INTEL)
 
-add_library(crc32 OBJECT ${crc32_srcs})
+add_library(crc32 STATIC ${crc32_srcs})
 
 if(HAVE_ARMV8_CRC)
   set_target_properties(crc32 PROPERTIES
--- a/src/arch/CMakeLists.txt
+++ b/src/arch/CMakeLists.txt
@@ -9,4 +9,4 @@
   list(APPEND arch_srcs ppc.c)
 endif()
 
-add_library(arch OBJECT ${arch_srcs})
+add_library(arch STATIC ${arch_srcs})
